# Salin file ini menjadi ".env" lalu isi sesuai kebutuhan.
# JANGAN commit file ".env" ke git (sudah masuk .gitignore).

# ========================
# DJANGO
# ========================
# Generate secret key baru dengan:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang

# Set ke False saat aplikasi sudah di-deploy ke server produksi
DJANGO_DEBUG=True

# Daftar domain/IP yang boleh diakses, pisahkan dengan koma
# Contoh production: DJANGO_ALLOWED_HOSTS=tokoborneoponsel.com,www.tokoborneoponsel.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins (wajib untuk Coolify/reverse proxy)
# Contoh: DJANGO_CSRF_TRUSTED_ORIGINS=https://tokoborneoponsel.com,https://www.tokoborneoponsel.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# ========================
# DATABASE (Production — PostgreSQL)
# ========================
# Kosongkan / jangan set DB_ENGINE untuk tetap pakai SQLite di lokal.
# Set DB_ENGINE=postgresql untuk pakai PostgreSQL (di Docker/Coolify).
# DB_ENGINE=postgresql
# DB_NAME=inventory_borneo
# DB_USER=borneo
# DB_PASSWORD=borneo_secret_db_2024
# DB_HOST=db
# DB_PORT=5432

# ========================
# SUPERUSER (untuk seed awal di production)
# ========================
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=admin123
# DJANGO_SUPERUSER_EMAIL=admin@example.com
